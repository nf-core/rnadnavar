params {
    // default parameters
    outdir = "results/"
    publish_dir_mode = "copy"    
}

// Resource limits for test environment (modern syntax)
process {
    resourceLimits = [
        cpus: 2,
        memory: 6.GB,
        time: 6.h
    ]
}

// Load modules.config for default module params
includeConfig '../../conf/modules.config'